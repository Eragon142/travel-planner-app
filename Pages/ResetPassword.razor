@page "/reset-password"
@attribute [AllowAnonymous]
@inject AppDbContext Db

<div class="auth-card">
    <h1>Reset hasła</h1>
    <p class="muted">Kod resetu jest wyświetlany na ekranie zamiast wysyłki e-mail.</p>
    @if(step == 1)
    {
        <div class="form">
            <label>E-mail</label><input @bind="email" type="email" />
            <button class="primary" @onclick="GenerateCode">Wyślij instrukcję</button>
        </div>
    }
    else
    {
        <div class="form">
            <div class="alert success">Kod resetu: <b>@resetCode</b></div>
            <label>Kod</label><input @bind="enteredCode" />
            <label>Nowe hasło</label><input @bind="newPassword" type="password" />
            <div class="progress"><span style="width:@PasswordStrength%"></span></div>
            <small>Siła hasła: @PasswordStrength%</small>
            <button class="primary" @onclick="SavePassword">Zapisz nowe hasło</button>
        </div>
    }
    @if(message != null){<div class="alert">@message</div>}
</div>

@code{
    string email="", resetCode="", enteredCode="", newPassword="", message=""; int step=1;
    int PasswordStrength => Math.Min(100, (newPassword.Length * 10) + (newPassword.Any(char.IsDigit)?20:0) + (newPassword.Any(ch=>!char.IsLetterOrDigit(ch))?20:0));
    async Task GenerateCode(){ var user=await Db.Users.FirstOrDefaultAsync(u=>u.Email==email); if(user==null){message="Nie znaleziono użytkownika."; return;} resetCode=Random.Shared.Next(100000,999999).ToString(); Db.PasswordResetCodes.Add(new PasswordResetCode{UserId=user.Id,Code=resetCode,ExpiresAt=DateTime.Now.AddMinutes(15)}); await Db.SaveChangesAsync(); step=2; }
    async Task SavePassword(){ var rec=await Db.PasswordResetCodes.Include(r=>r.User).FirstOrDefaultAsync(r=>r.Code==enteredCode && !r.Used && r.ExpiresAt>DateTime.Now); if(rec==null){message="Kod jest niepoprawny lub wygasł."; return;} if(PasswordStrength<60){message="Hasło jest za słabe."; return;} rec.User.PasswordHash=AuthService.HashPassword(newPassword); rec.Used=true; await Db.SaveChangesAsync(); message="Hasło zmienione. Możesz się zalogować."; }
}
